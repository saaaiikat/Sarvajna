{
  "name": "@sarvajna/server",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "postinstall": "bun run --cwd ../database db:generate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.5",
    "@ai-sdk/google": "^4.0.8",
    "@ai-sdk/openai": "^4.0.5",
    "@hono/zod-validator": "^0.8.0",
    "@sarvajna/database": "workspace:*",
    "@sarvajna/shared": "workspace:*",
    "@sentry/bun": "^10.62.0",
    "@sentry/hono": "^10.62.0",
    "ai": "^7.0.11",
    "dotenv": "^17.4.2",
    "hono": "^4.12.25",
    "zod": "^4.4.3"
  }
}
